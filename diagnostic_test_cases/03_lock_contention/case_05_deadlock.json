        {
            "solution": "缩短事务持有锁时间",
            "description": "减少事务中的非必要操作，尽快提交",
            "best_practice": "将非数据库操作移到事务外，减少事务持续时间"
        },
        {
            "solution": "使用乐观锁替代悲观锁",
            "description": "使用版本号或时间戳实现乐观并发控制",
            "sql_example": "UPDATE products SET stock = stock - 1, version = version + 1 WHERE id = 1 AND version = 10;"
        },
        {
            "solution": "设置锁超时",
            "description": "配置合理的锁等待超时时间",
            "config_example": "SET lock_timeout = '10s';"
        },
        {
            "solution": "增加热点数据索引",
            "description": "减少锁定的行数和范围",
            "sql_example": "CREATE INDEX idx_products_id ON products(id);"
        }
