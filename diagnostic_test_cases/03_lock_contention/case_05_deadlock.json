    "expected_solutions": [
        {
            "solution": "统一资源访问顺序",
            "description": "确保所有事务按相同顺序访问表和行",
            "sql_example": "-- 所有事务都按 表A -> 表B 的顺序更新\nBEGIN;\nUPDATE table_a SET ... WHERE id = 1;\nUPDATE table_b SET ... WHERE id = 1;\nCOMMIT;"
