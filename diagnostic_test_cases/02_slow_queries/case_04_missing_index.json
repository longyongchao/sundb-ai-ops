    "expected_solutions": [
        {
            "solution": "为JOIN关联字段创建索引",
            "description": "为多表关联的外键字段创建索引",
            "sql_example": "CREATE INDEX idx_order_items_order_id ON order_items(order_id); CREATE INDEX idx_orders_customer_id ON orders(customer_id);"
        },
        {
            "solution": "创建覆盖索引",
            "description": "创建包含查询所需全部字段的复合索引",
            "sql_example": "CREATE INDEX idx_orders_covering ON orders(customer_id, status) INCLUDE (order_date, total_amount);"
        },
        {
            "solution": "增加work_mem配置",
            "description": "提高排序和哈希操作的内存上限",
            "config_example": "SET work_mem = '256MB'; 或在postgresql.conf中设置"
        },
        {
            "solution": "优化查询语句",
            "description": "重写查询减少JOIN数量，使用EXISTS替代IN",
            "sql_example": "SELECT * FROM orders o WHERE EXISTS (SELECT 1 FROM order_items oi WHERE oi.order_id = o.id);"
        }
