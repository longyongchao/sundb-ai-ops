    "expected_root_causes": [
        {
            "cause": "检查点间隔过短",
            "description": "checkpoint_timeout设置过短，导致检查点频繁触发",
            "confidence": 0.95
        },
        {
            "cause": "检查点写入过于集中",
            "description": "checkpoint_completion_target设置过小，检查点写入过于集中",
            "confidence": 0.90
        },
        {
            "cause": "WAL写入量过大",
            "description": "大量写入操作产生过多WAL日志",
            "confidence": 0.85
        }
    ],
    "expected_solutions": [
        {
            "solution": "增加检查点间隔",
            "description": "将checkpoint_timeout从默认值增加到更长间隔",
            "config_example": "ALTER SYSTEM SET checkpoint_timeout = '15min'; SELECT pg_reload_conf();"
        },
        {
            "solution": "调整检查点完成目标",
            "description": "增加checkpoint_completion_target使写入更平滑",
            "config_example": "ALTER SYSTEM SET checkpoint_completion_target = 0.9; SELECT pg_reload_conf();"
        },
        {
            "solution": "增加WAL缓冲区",
            "description": "增加wal_buffers减少WAL写入频率",
            "config_example": "ALTER SYSTEM SET wal_buffers = '64MB'; SELECT pg_reload_conf();"
        },
        {
            "solution": "使用SSD或增加磁盘带宽",
            "description": "升级存储设备提升I/O性能",
            "hardware_suggestion": "建议使用NVMe SSD，或增加磁盘阵列带宽"
        }
    ],
