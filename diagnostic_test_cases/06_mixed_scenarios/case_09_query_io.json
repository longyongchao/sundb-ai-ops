        }
    ],
    "expected_solutions": [
        {
            "solution": "为查询条件创建索引",
            "description": "减少全表扫描，降低磁盘读取",
            "sql_example": "CREATE INDEX idx_table_column ON table_name(column);"
        },
        {
            "solution": "增加shared_buffers",
            "description": "提高缓存容量，增加命中率",
            "config_example": "ALTER SYSTEM SET shared_buffers = '4GB';"
        },
        {
            "solution": "预热热点数据",
            "description": "启动后预热常用表到缓存",
            "sql_example": "SELECT pg_prewarm('hot_table');"
        }
