        {
            "solution": "执行VACUUM FULL",
            "description": "回收空间，但会锁表",
            "sql_example": "VACUUM FULL table_name;"
        },
        {
            "solution": "使用pg_repack",
            "description": "在线重建表，不锁表",
            "sql_example": "pg_repack --table=table_name -d database_name"
        },
        {
            "solution": "调整autovacuum参数",
            "description": "降低触发阈值，增加执行频率",
            "config_example": "ALTER TABLE table_name SET (autovacuum_vacuum_scale_factor = 0.05, autovacuum_vacuum_threshold = 1000);"
        },
        {
            "solution": "增加autovacuum worker",
            "description": "增加并行autovacuum进程数",
            "config_example": "ALTER SYSTEM SET autovacuum_max_workers = 5; SELECT pg_reload_conf();"
        }
