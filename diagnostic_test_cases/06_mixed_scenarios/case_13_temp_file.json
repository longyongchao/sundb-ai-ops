            "description": "work_mem=64MB不足以处理大量排序操作",
            "confidence": 0.95
        },
        {
            "cause": "大表排序操作",
            "description": "多个查询对大表进行排序，溢出到磁盘",
            "confidence": 0.90
        }
    ],
    "expected_solutions": [
        {
            "solution": "增加work_mem配置",
            "description": "提高排序和哈希操作的内存上限",
            "config_example": "ALTER SYSTEM SET work_mem = '256MB'; SELECT pg_reload_conf();"
        },
        {
            "solution": "为排序字段创建索引",
            "description": "避免排序操作，使用索引顺序",
            "sql_example": "CREATE INDEX idx_table_sort_col ON table_name(sort_column);"
        },
        {
            "solution": "调整temp_file_limit",
            "description": "限制单个查询可使用的临时文件大小",
            "config_example": "ALTER SYSTEM SET temp_file_limit = '10GB'; SELECT pg_reload_conf();"
        }
    ],
