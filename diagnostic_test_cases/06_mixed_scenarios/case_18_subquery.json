            "solution": "使用CTE优化",
            "description": "将子查询提取为CTE，避免重复计算",
            "sql_example": "WITH active_users AS (SELECT id FROM users WHERE status = 'active') SELECT * FROM orders WHERE user_id IN (SELECT id FROM active_users);"
