# DeepSeek API (LLM provider)
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# LLM thinking/reasoning mode (GLM models support this)
# Set to true to enable deep thinking, false to disable
LLM_THINKING_ENABLED=false

# PostgreSQL connection
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your-password-here
PG_DATABASE=dbgpt_metadata

# Default admin password (for initial setup only)
DEFAULT_ADMIN_PASSWORD=change-me-on-first-login

# ---- LILAC Log Parser ----
# SQLite cache file path (relative to project root)
LILAC_CACHE_DB_PATH=data/lilac_cache.db
# Cache similarity threshold (0.0-1.0, higher = stricter matching)
LILAC_CACHE_SIMILARITY_THRESHOLD=0.85
# LLM temperature for template extraction
LILAC_LLM_TEMPERATURE=0.0
# LLM call timeout in seconds
LILAC_LLM_TIMEOUT=10.0
# Maximum demonstrations in ICL example pool
LILAC_DEMO_POOL_MAX=500
# Number of ICL examples sampled per LLM call
LILAC_DEMO_SAMPLE_K=8
# Enable LLM-based template extraction (true/false)
LILAC_ENABLE_LLM=true
# Enable Drain3 fallback when LLM fails (true/false)
LILAC_ENABLE_DRAIN3=true
