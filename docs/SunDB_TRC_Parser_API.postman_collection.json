              "raw": "{{baseUrl}}/diagnose/trc/aeu_list",
              "host": ["{{baseUrl}}"],
              "path": ["diagnose", "trc", "aeu_list"]
            },
            "description": "Step 4: 获取 AEU 列表用于 Citation 检索"
          },
          "response": []
        }
      ]
    }
  ]
}
