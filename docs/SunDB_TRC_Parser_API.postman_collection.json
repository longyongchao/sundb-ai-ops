        {
          "name": "Step 2: 查看故障事件",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/diagnose/trc/fault_events",
              "host": ["{{baseUrl}}"],
              "path": ["diagnose", "trc", "fault_events"]
            },
            "description": "Step 2: 查看解析出的故障事件"
          },
          "response": []
        },
        {
          "name": "Step 3: 查看时间线",
          "request": {
